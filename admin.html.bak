<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Admin - ROCKOLA</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #0a0a0f;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(255, 0, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(0, 255, 255, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 40% 20%, rgba(255, 255, 0, 0.03) 0%, transparent 50%);
            min-height: 100vh;
            padding: 20px;
            color: #e0e0e0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            background: linear-gradient(90deg, #ff00ff, #00ffff, #ffff00, #ff00ff);
            background-size: 300% 300%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: neonFlow 4s ease infinite;
            filter: drop-shadow(0 0 20px rgba(255, 0, 255, 0.6));
        }

        @keyframes neonFlow {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .subtitle {
            font-size: 1.1em;
            color: #00ffff;
            text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
        }

        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, #1a1a2e 0%, #16162a 100%);
            padding: 25px;
            border-radius: 16px;
            border: 1px solid rgba(255, 0, 255, 0.3);
            box-shadow: 
                0 0 20px rgba(255, 0, 255, 0.2),
                0 10px 30px rgba(0, 0, 0, 0.5);
            animation: slideUp 0.6s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stat-card h3 {
            color: #ffff00;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(255, 255, 0, 0.5);
        }

        .stat-value {
            font-size: 2.5em;
            font-weight: bold;
            background: linear-gradient(135deg, #ff00ff, #00ffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .action-panel {
            background: linear-gradient(135deg, #1a1a2e 0%, #16162a 100%);
            padding: 30px;
            border-radius: 16px;
            margin-bottom: 30px;
            border: 1px solid rgba(0, 255, 255, 0.3);
            box-shadow: 
                0 0 20px rgba(0, 255, 255, 0.2),
                0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .action-panel h2 {
            color: #00ffff;
            margin-bottom: 20px;
            text-shadow: 0 0 15px rgba(0, 255, 255, 0.8);
        }

        .btn {
            padding: 15px 30px;
            border: none;
            border-radius: 12px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
        }

        .btn-generate {
            background: linear-gradient(135deg, #ff00ff 0%, #00ffff 100%);
            color: #000;
            box-shadow: 
                0 0 20px rgba(255, 0, 255, 0.5),
                0 0 40px rgba(0, 255, 255, 0.3);
        }

        .btn-generate::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transform: rotate(45deg);
            animation: shine 3s infinite;
        }

        @keyframes shine {
            0% { left: -50%; }
            100% { left: 150%; }
        }

        .btn-generate:hover {
            transform: translateY(-3px);
            box-shadow: 
                0 0 30px rgba(255, 0, 255, 0.8),
                0 0 60px rgba(0, 255, 255, 0.5);
        }

        .btn-custom {
            background: linear-gradient(135deg, #ffff00 0%, #ff00ff 100%);
            color: #000;
            box-shadow: 
                0 0 20px rgba(255, 255, 0, 0.5),
                0 0 40px rgba(255, 0, 255, 0.3);
        }

        .btn-custom::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transform: rotate(45deg);
            animation: shine 3s infinite;
        }

        .btn-custom:hover {
            transform: translateY(-3px);
            box-shadow: 
                0 0 30px rgba(255, 255, 0, 0.8),
                0 0 60px rgba(255, 0, 255, 0.5);
        }

        .btn-delete {
            background: linear-gradient(135deg, #ff0066, #ff3366);
            color: white;
            padding: 8px 16px;
            font-size: 0.85em;
            box-shadow: 0 0 15px rgba(255, 0, 100, 0.4);
        }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(255, 0, 100, 0.6);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
        }

        .custom-input-container {
            margin-top: 20px;
            animation: slideDown 0.4s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .custom-input-container input {
            width: 100%;
            padding: 14px;
            border: 2px solid rgba(0, 255, 255, 0.3);
            border-radius: 12px;
            background: rgba(10, 10, 20, 0.8);
            color: #e0e0e0;
            font-size: 1em;
            transition: all 0.3s ease;
            box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        .custom-input-container input:focus {
            outline: none;
            border-color: #00ffff;
            box-shadow: 
                0 0 20px rgba(0, 255, 255, 0.4),
                inset 0 2px 4px rgba(0, 0, 0, 0.3);
            background: rgba(0, 20, 30, 0.9);
        }

        .custom-input-container label {
            display: block;
            margin-bottom: 8px;
            color: #00ffff;
            font-weight: 600;
            text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
        }

        .btn-cancel {
            background: rgba(255, 0, 0, 0.2);
            color: #ff6666;
            border: 1px solid rgba(255, 0, 0, 0.4);
            padding: 14px 25px;
        }

        .btn-cancel:hover {
            background: rgba(255, 0, 0, 0.3);
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.4);
        }

        .codes-section {
            background: linear-gradient(135deg, #1a1a2e 0%, #16162a 100%);
            padding: 30px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 0, 0.3);
            box-shadow: 
                0 0 20px rgba(255, 255, 0, 0.2),
                0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .codes-section h2 {
            color: #ffff00;
            margin-bottom: 25px;
            text-shadow: 0 0 15px rgba(255, 255, 0, 0.8);
        }

        .codes-grid {
            display: grid;
            gap: 15px;
        }

        .code-card {
            background: rgba(10, 10, 20, 0.6);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid rgba(255, 0, 255, 0.2);
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 15px;
            align-items: center;
            transition: all 0.3s ease;
        }

        .code-card:hover {
            border-color: rgba(255, 0, 255, 0.5);
            box-shadow: 0 0 20px rgba(255, 0, 255, 0.3);
            transform: translateX(5px);
        }

        .code-card.expired {
            opacity: 0.5;
            border-color: rgba(255, 0, 0, 0.3);
        }

        .code-card.admin {
            border-color: rgba(255, 215, 0, 0.5);
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.2);
        }

        .code-name {
            font-size: 1.2em;
            font-weight: 600;
            color: #ff00ff;
            text-shadow: 0 0 10px rgba(255, 0, 255, 0.6);
        }

        .code-info {
            font-size: 0.9em;
            color: #b0b0b0;
        }

        .code-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            text-align: center;
        }

        .status-active {
            background: rgba(0, 255, 100, 0.2);
            color: #00ff66;
            border: 1px solid rgba(0, 255, 100, 0.4);
        }

        .status-expired {
            background: rgba(255, 0, 0, 0.2);
            color: #ff6666;
            border: 1px solid rgba(255, 0, 0, 0.4);
        }

        .status-admin {
            background: rgba(255, 215, 0, 0.2);
            color: #ffd700;
            border: 1px solid rgba(255, 215, 0, 0.4);
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(0, 255, 255, 0.3);
            border-top-color: #00ffff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-right: 10px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }

        .empty-state svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.3;
        }

        @media (max-width: 768px) {
            .code-card {
                grid-template-columns: 1fr;
                text-align: center;
            }
            
            header h1 {
                font-size: 2em;
            }
        }

        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(135deg, #1a1a2e, #16162a);
            color: white;
            padding: 20px 25px;
            border-radius: 12px;
            box-shadow: 
                0 0 30px rgba(255, 0, 255, 0.5),
                0 10px 40px rgba(0, 0, 0, 0.7);
            border: 1px solid rgba(0, 255, 255, 0.4);
            animation: slideInRight 0.4s ease;
            z-index: 1000;
            display: none;
        }

        .toast.show {
            display: block;
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .loading-overlay.show {
            display: flex;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🎛️ Panel de Administración</h1>
            <p class="subtitle">Gestiona los códigos de acceso de ROCKOLA</p>
        </header>

        <div class="stats-container">
            <div class="stat-card">
                <h3>📊 Total Códigos</h3>
                <div class="stat-value" id="total-codes">0</div>
            </div>
            <div class="stat-card">
                <h3>✅ Activos</h3>
                <div class="stat-value" id="active-codes">0</div>
            </div>
            <div class="stat-card">
                <h3>⏰ Expirados</h3>
                <div class="stat-value" id="expired-codes">0</div>
            </div>
            <div class="stat-card">
                <h3>🔥 Más Usado</h3>
                <div class="stat-value" id="most-used" style="font-size: 1.2em;">-</div>
            </div>
        </div>

        <div class="action-panel">
            <h2>⚡ Generar Nuevo Código</h2>
            <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
                <button class="btn btn-generate" onclick="generateCode()">
                    🎲 Generar Código Aleatorio
                </button>
                <button class="btn btn-custom" onclick="toggleCustomInput()">
                    ✍️ Crear Código Personalizado
                </button>
            </div>
            
            <div id="custom-input-container" class="custom-input-container" style="display: none;">
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 250px;">
                        <label>Escribe tu código:</label>
                        <input 
                            type="text" 
                            id="custom-code-input" 
                            placeholder="Ejemplo: taquitos al pastor"
                            onkeypress="if(event.key === 'Enter') createCustomCode()"
                        />
                    </div>
                    <div style="display: flex; gap: 10px; align-items: flex-end;">
                        <button class="btn btn-generate" onclick="createCustomCode()" style="padding: 14px 25px;">
                            ✅ Crear
                        </button>
                        <button class="btn btn-cancel" onclick="toggleCustomInput()">
                            ❌ Cancelar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="codes-section">
            <h2>🎫 Códigos Registrados</h2>
            <div id="codes-grid" class="codes-grid">
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <p>Cargando códigos...</p>
                </div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>
    <div id="loading-overlay" class="loading-overlay">
        <div class="spinner" style="width: 60px; height: 60px; border-width: 5px;"></div>
    </div>

    <script>
        function toggleCustomInput() {
            const container = document.getElementById('custom-input-container');
            const input = document.getElementById('custom-code-input');
            
            if (container.style.display === 'none') {
                container.style.display = 'block';
                setTimeout(() => input.focus(), 100);
            } else {
                container.style.display = 'none';
                input.value = '';
            }
        }

        async function createCustomCode() {
            const input = document.getElementById('custom-code-input');
            const code = input.value.trim();
            
            if (!code) {
                showToast('⚠️ Por favor escribe un código');
                input.focus();
                return;
            }
            
            setLoading(true);
            try {
                const formData = new FormData();
                formData.append('custom_code', code);
                formData.append('days', 30);
                
                const response = await fetch('/api/admin/generate_code', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.error) {
                    showToast('❌ ' + result.error);
                } else {
                    showToast('✅ Código creado: ' + result.code);
                    input.value = '';
                    toggleCustomInput();
                    loadCodes();
                }
            } catch (error) {
                console.error('Error creando código:', error);
                showToast('❌ Error al crear código');
            } finally {
                setLoading(false);
            }
        }

        function showToast(message, duration = 3000) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, duration);
        }

        function setLoading(show) {
            const overlay = document.getElementById('loading-overlay');
            overlay.classList.toggle('show', show);
        }

        async function loadCodes() {
            try {
                const response = await fetch('/api/admin/codes');
                const data = await response.json();
                
                const codes = data.codes || [];
                
                const total = codes.length;
                const active = codes.filter(c => !c.is_expired).length;
                const expired = codes.filter(c => c.is_expired).length;
                
                document.getElementById('total-codes').textContent = total;
                document.getElementById('active-codes').textContent = active;
                document.getElementById('expired-codes').textContent = expired;
                
                if (codes.length > 0) {
                    const mostUsed = codes.reduce((prev, curr) => 
                        (curr.used_count || 0) > (prev.used_count || 0) ? curr : prev
                    );
                    document.getElementById('most-used').textContent = mostUsed.code;
                }
                
                const grid = document.getElementById('codes-grid');
                
                if (codes.length === 0) {
                    grid.innerHTML = `
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                            <p>No hay códigos registrados. ¡Genera uno!</p>
                        </div>
                    `;
                    return;
                }
                
                grid.innerHTML = codes.map(code => {
                    const isAdmin = code.is_admin;
                    const isExpired = code.is_expired;
                    const statusClass = isAdmin ? 'admin' : (isExpired ? 'expired' : 'active');
                    const statusText = isAdmin ? 'ADMIN' : (isExpired ? 'Expirado' : 'Activo');
                    
                    const expiryDate = code.expires_at ? 
                        new Date(code.expires_at).toLocaleDateString('es-MX') : 
                        'Permanente';
                    
                    return `
                        <div class="code-card ${isExpired ? 'expired' : ''} ${isAdmin ? 'admin' : ''}">
                            <div>
                                <div class="code-name">${code.code}</div>
                                <div class="code-info">Usos: ${code.used_count || 0}</div>
                            </div>
                            <div class="code-info">
                                Expira: ${expiryDate}
                            </div>
                            <div>
                                <span class="code-status status-${statusClass}">${statusText}</span>
                            </div>
                            <div>
                                ${!isAdmin ? `
                                    <button class="btn btn-delete" onclick="deleteCode('${code.code}')">
                                        🗑️ Eliminar
                                    </button>
                                ` : '<span style="color: #ffd700;">🔒 Protegido</span>'}
                            </div>
                        </div>
                    `;
                }).join('');
                
            } catch (error) {
                console.error('Error cargando códigos:', error);
                showToast('❌ Error al cargar códigos');
            }
        }

        async function generateCode() {
            setLoading(true);
            try {
                const formData = new FormData();
                formData.append('days', 30);
                
                const response = await fetch('/api/admin/generate_code', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.error) {
                    showToast('❌ ' + result.error);
                } else {
                    showToast('✅ Código generado: ' + result.code);
                    loadCodes();
                }
            } catch (error) {
                console.error('Error generando código:', error);
                showToast('❌ Error al generar código');
            } finally {
                setLoading(false);
            }
        }

        async function deleteCode(code) {
            if (!confirm(`¿Eliminar el código "${code}"?`)) return;
            
            setLoading(true);
            try {
                const formData = new FormData();
                formData.append('code', code);
                
                const response = await fetch('/api/admin/delete_code', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast('✅ Código eliminado');
                    loadCodes();
                } else {
                    showToast('❌ ' + result.message);
                }
            } catch (error) {
                console.error('Error eliminando código:', error);
                showToast('❌ Error al eliminar código');
            } finally {
                setLoading(false);
            }
        }

        loadCodes();
        setInterval(loadCodes, 30000);
    </script>
</body>
</html>